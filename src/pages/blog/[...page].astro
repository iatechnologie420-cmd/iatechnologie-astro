---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Navbar from '@/components/Navbar.astro';
import Footer from '@/components/Footer.astro';
import { getCollection } from 'astro:content';
import type { Page, GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const allArticles = await getCollection('articles');
  const sortedPosts = allArticles.sort(
    (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
  );
  
  return paginate(sortedPosts, { pageSize: 9 });
};

const { page } = Astro.props as { page: Page };
const posts = page.data;

const formatDate = (dateString: string) =>
  new Date(dateString).toLocaleDateString('fr-FR', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
---

<BaseLayout
  title={`Blog IA — Page ${page.currentPage} | IA Technologie`}
  description="Découvrez les dernières tendances, tutoriels et actualités sur l'Intelligence Artificielle."
>
  <div class="min-h-screen bg-background">
    <Navbar />
    <main class="py-24">
      <div class="container">
        <div class="mb-16 text-center">
          <span class="mb-4 inline-block rounded-full bg-primary/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-primary">Blog</span>
          <h1 class="mb-4 font-heading text-4xl font-bold text-foreground md:text-5xl">
            Notre <span class="gradient-text">Blog IA</span>
          </h1>
          <p class="mx-auto max-w-2xl text-muted-foreground">
            Découvrez les dernières tendances, tutoriels et actualités sur l'Intelligence Artificielle.
          </p>
        </div>

        {posts.length === 0 ? (
          <div class="rounded-2xl border border-dashed border-border py-16 text-center glass-card">
            <p class="text-muted-foreground">Aucun article publié pour le moment.</p>
          </div>
        ) : (
          <>
            <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
              {posts.map((post, i) => (
                <a
                  href={`/${post.data.slug}`}
                  class="group relative h-full flex flex-col overflow-hidden rounded-2xl glass-card text-left transition-all duration-500 hover:border-primary/30 hover:shadow-xl hover:shadow-primary/5 hover:-translate-y-2 cursor-pointer"
                  style={`transition-delay: ${i * 0.05}s;`}
                >
                  {post.data.featuredImage ? (
                    <div class="relative h-48 overflow-hidden bg-muted animate-pulse group-data-[loaded=true]:animate-none">
                      <img 
                        src={post.data.featuredImage} 
                        alt={post.data.title} 
                        class="h-full w-full object-cover transition-all duration-700 group-hover:scale-110 opacity-0 data-[loaded=true]:opacity-100" 
                        loading={i < 6 ? "eager" : "lazy"}
                        decoding="async"
                        onload="this.parentElement.setAttribute('data-loaded', 'true'); this.setAttribute('data-loaded', 'true')"
                      />
                    </div>
                  ) : (
                    <div class="relative h-48 bg-muted flex items-center justify-center">
                      <span class="text-muted-foreground">Pas d'image</span>
                    </div>
                  )}
                  <div class="flex flex-1 flex-col p-6">
                    <div class="mb-3 flex items-center gap-2 text-xs text-muted-foreground">
                      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                      </svg>
                      <time datetime={post.data.date}>{formatDate(post.data.date)}</time>
                    </div>
                    <h2 class="mb-3 font-heading text-xl font-bold leading-tight text-foreground transition-colors group-hover:text-primary">
                      {post.data.title}
                    </h2>
                    <p class="mb-6 flex-1 text-sm text-muted-foreground line-clamp-3">{post.data.excerpt}</p>
                    <div class="mt-auto flex items-center text-sm font-semibold text-primary">
                      Lire l'article
                      <svg class="ml-2 h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                      </svg>
                    </div>
                  </div>
                </a>
              ))}
            </div>

            {/* Pagination Controls */}
            <div class="mt-16 flex items-center justify-center gap-4">
              {page.url.prev ? (
                <a
                  href={page.url.prev}
                  class="flex items-center gap-2 rounded-xl border border-border px-6 py-3 text-sm font-semibold text-foreground transition-all hover:border-primary/30 hover:bg-primary/5"
                >
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                  </svg>
                  Précédent
                </a>
              ) : (
                <span class="flex items-center gap-2 rounded-xl border border-border/50 px-6 py-3 text-sm font-semibold text-muted-foreground opacity-50 cursor-not-allowed">
                   <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                  </svg>
                  Précédent
                </span>
              )}

              <div class="flex items-center gap-2">
                <span class="text-sm text-muted-foreground">
                  Page <span class="font-bold text-foreground">{page.currentPage}</span> sur {page.lastPage}
                </span>
              </div>

              {page.url.next ? (
                <a
                  href={page.url.next}
                  class="flex items-center gap-2 rounded-xl border border-border px-6 py-3 text-sm font-semibold text-foreground transition-all hover:border-primary/30 hover:bg-primary/5"
                >
                  Suivant
                  <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                  </svg>
                </a>
              ) : (
                <span class="flex items-center gap-2 rounded-xl border border-border/50 px-6 py-3 text-sm font-semibold text-muted-foreground opacity-50 cursor-not-allowed">
                  Suivant
                   <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                  </svg>
                </span>
              )}
            </div>
          </>
        )}
      </div>
    </main>
    <Footer />
  </div>
</BaseLayout>
