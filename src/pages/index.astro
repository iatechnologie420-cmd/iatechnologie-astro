---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Navbar from '@/components/Navbar.astro';
import HeroSection from '@/components/HeroSection.astro';
import LogoMarquee from '@/components/LogoMarquee.astro';
import UseCasesSection from '@/components/UseCasesSection.astro';
import CategoriesSection from '@/components/CategoriesSection.astro';
import HowItWorksSection from '@/components/HowItWorksSection.astro';
import ToolsSection from '@/components/ToolsSection.astro';
import TestimonialsSection from '@/components/TestimonialsSection.astro';
import YouTubeSection from '@/components/YouTubeSection.astro';
import SeoSection from '@/components/SeoSection.astro';
import CtaSection from '@/components/CtaSection.astro';
import Footer from '@/components/Footer.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'IA Technologie',
  url: 'https://iatechnologie.com',
  description: "Découvrez les meilleurs outils IA pour chaque besoin. Trouvez, comparez et utilisez les outils d'intelligence artificielle les plus performants.",
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://iatechnologie.com/?s={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};
---

<BaseLayout
  title="L'annuaire des meilleurs outils IA 2026 : comparatif, avis et guide complet — IA Technologie"
  jsonLd={jsonLd}
>
  <div class="min-h-screen bg-background">
    <Navbar />
    <main>
      <HeroSection />
      <LogoMarquee />
      <UseCasesSection />
      <CategoriesSection />
      <HowItWorksSection />
      <ToolsSection />
      <TestimonialsSection />
      <YouTubeSection />
      <SeoSection />
      <CtaSection />
    </main>
    <Footer />
  </div>
</BaseLayout>
