---
import '@/styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description = "L'annuaire expert des meilleurs outils d'Intelligence Artificielle en 2026. Trouvez, comparez et maîtrisez l'IA pour booster votre productivité grâce à nos tests et guides complets.",
  canonical,
  ogImage = 'https://storage.googleapis.com/gpt-engineer-file-uploads/b0drPDn3ZvcJn2jHDGaBhnXuMWq2/social-images/social-1772964214434-channels4_profile-8.webp',
  jsonLd,
  lang = 'fr',
} = Astro.props;

const siteUrl = 'https://iatechnologie.com';
const canonicalUrl = canonical || new URL(Astro.url.pathname, siteUrl).toString();

// Gestion des langues supportées
const supportedLangs = ['it', 'es', 'en', 'de', 'ro', 'sl', 'tr'];
---

<!doctype html>
<html lang={lang} class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Hreflang Tags (SEO International) -->
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}/blog`} />
    <link rel="alternate" hreflang="fr" href={`${siteUrl}/blog`} />
    {supportedLangs.map((l) => (
      <link rel="alternate" hreflang={l} href={`${siteUrl}/${l}/blog`} />
    ))}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- JSON-LD -->
    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
  </head>
  <body class="bg-background text-foreground antialiased selection:bg-primary/30 selection:text-primary">
    <slot />
    
    <script is:inline>
      // Détection de la langue du visiteur
      const supportedLangs = ['it', 'es', 'en', 'de', 'ro', 'sl', 'tr'];
      const userLang = navigator.language.split('-')[0];
      const currentPath = window.location.pathname;

      // Si l'utilisateur est sur la page blog par défaut (FR) et qu'on a sa langue
      if (currentPath === '/blog' || currentPath === '/blog/') {
        if (supportedLangs.includes(userLang)) {
          // Redirection vers la version localisée
          window.location.href = `/${userLang}/blog`;
        }
      }
    </script>
  </body>
</html>
