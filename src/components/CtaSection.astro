---
// CtaSection.astro — CTA final avant/après + formulaire newsletter
---

<section class="py-20 lg:py-28 relative overflow-hidden">
  <!-- Background sombre contrasté -->
  <div class="absolute inset-0 bg-gradient-to-br from-brand-surface via-brand-surface to-brand-surface"></div>
  
  <!-- Noise texture -->
  <div class="absolute inset-0 noise-bg"></div>
  
  <!-- Orbs -->
  <div class="absolute top-0 left-1/4 h-60 w-60 rounded-full bg-primary/10 blur-3xl" style="animation: float-orb 8s ease-in-out infinite;"></div>
  <div class="absolute bottom-0 right-1/4 h-80 w-80 rounded-full bg-accent/5 blur-3xl" style="animation: float-orb 10s ease-in-out infinite 1s;"></div>

  <div class="container max-w-5xl mx-auto px-4 md:px-8 relative z-10">
    <!-- Title -->
    <div class="text-center mb-14">
      <h2 class="font-heading text-3xl font-bold text-brand-surface-fg md:text-4xl lg:text-5xl tracking-tight mb-4">
        Ne soyez plus le dernier à découvrir <br class="hidden md:block" />
        <span class="gradient-text">l'outil qui change tout.</span>
      </h2>
    </div>

    <!-- Avant / Après -->
    <div class="grid gap-6 md:grid-cols-2 mb-14 max-w-3xl mx-auto">
      <!-- Avant -->
      <div class="rounded-2xl border border-red-500/20 bg-red-500/5 p-6">
        <div class="flex items-center gap-2 mb-4">
          <svg class="h-5 w-5 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
          <span class="font-heading font-bold text-red-400 text-sm uppercase tracking-wider">Avant</span>
        </div>
        <ul class="space-y-3 text-sm text-brand-surface-fg/70">
          <li class="flex items-start gap-2">
            <span class="mt-1 text-red-400/60">—</span>
            <span>Des heures sur Google à tester des outils décevants</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-1 text-red-400/60">—</span>
            <span>Vous apprenez les lancements avec 3 semaines de retard</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-1 text-red-400/60">—</span>
            <span>Vos concurrents avancent plus vite que vous</span>
          </li>
        </ul>
      </div>

      <!-- Après -->
      <div class="rounded-2xl border border-primary/20 bg-primary/5 p-6">
        <div class="flex items-center gap-2 mb-4">
          <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
          <span class="font-heading font-bold text-primary text-sm uppercase tracking-wider">Après</span>
        </div>
        <ul class="space-y-3 text-sm text-brand-surface-fg/70">
          <li class="flex items-start gap-2">
            <span class="mt-1 text-primary/60">✓</span>
            <span>3 outils testés et validés chaque jeudi dans votre boîte</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-1 text-primary/60">✓</span>
            <span>Premiers sur les lancements, avant tout le monde</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-1 text-primary/60">✓</span>
            <span>Vous avancez plus vite que 95% de votre marché</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- CTA form -->
    <div class="text-center">
      <form 
        id="bottom-newsletter-form" 
        action="https://a9004679.sibforms.com/serve/MUIFACbRWtBQ58ZmHzft3_TYeb6dgjn8pxrvkPC4295ca3r6HbKwB6l48zrrXllACuSgL9wreMo-NLKumsoeeGZuh7cMZpAXoRPqk00rvRE8kb5AM5-Hq3QfTxNBvuOo-u15nR0Ir-rqLA3HAyb8X8h8pkvDgfdhzkf85zkwp3R2LJ4mKXqeZD-dpkrLcAqIMmq0uxaHh2JxaESzPQ=="
        method="POST"
        class="mx-auto flex max-w-md flex-col gap-3 sm:flex-row sm:gap-0 sm:p-1.5 sm:bg-white/10 sm:backdrop-blur-xl sm:rounded-full sm:border sm:border-white/15 sm:shadow-2xl transition-all"
      >
        <input 
          type="email" 
          name="EMAIL"
          placeholder="votre@email.com" 
          class="w-full flex-1 rounded-full border border-white/15 sm:border-0 bg-white/10 sm:bg-transparent px-6 py-3.5 text-base text-brand-surface-fg placeholder-brand-surface-fg/40 focus:outline-none focus:ring-2 focus:ring-primary/40 sm:focus:ring-0"
          required
          id="cta-email-input"
        />
        <input type="text" name="email_address_check" value="" class="hidden" aria-hidden="true" />
        <input type="hidden" name="locale" value="fr" />
        <button 
          type="submit" 
          class="inline-flex items-center justify-center rounded-full bg-primary px-8 py-3.5 text-base font-bold text-primary-foreground transition-all hover:scale-105 shadow-lg shadow-primary/30 whitespace-nowrap"
        >
          Recevoir la sélection
        </button>
      </form>

      <!-- Message de succès -->
      <div id="bottom-success-message" class="hidden mx-auto max-w-md py-4 px-6 rounded-2xl bg-white/5 border border-white/10 text-brand-surface-fg font-bold animate-in fade-in zoom-in duration-300">
        🚀 C'est parti ! On se retrouve jeudi prochain.
      </div>

      <!-- Reassurance -->
      <p class="mt-4 text-sm text-brand-surface-fg/50">
        Gratuit · Pas de spam · Désinscription en 1 clic
      </p>
      <p class="mt-2 text-xs text-brand-surface-fg/40">
        Rejoignez les <span class="font-semibold text-brand-surface-fg/60">10 400+</span> professionnels qui ne ratent plus rien en IA.
      </p>
    </div>
  </div>
</section>

<script>
  const bottomForm = document.getElementById('bottom-newsletter-form') as HTMLFormElement;
  const bottomSuccess = document.getElementById('bottom-success-message');

  bottomForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(bottomForm);
    
    try {
      fetch(bottomForm.action, {
        method: 'POST',
        body: formData,
        mode: 'no-cors'
      });
      bottomForm.classList.add('hidden');
      bottomSuccess?.classList.remove('hidden');
    } catch (err) {
      console.error('Erreur:', err);
      bottomForm.classList.add('hidden');
      bottomSuccess?.classList.remove('hidden');
    }
  });
</script>
