---
---

<section class="py-24">
  <div class="container">
    <div class="relative overflow-hidden rounded-3xl px-8 py-20 text-center md:px-16 ">
      <div class="absolute inset-0 bg-gradient-to-br from-primary via-primary/90 to-primary-glow"></div>

      <div class="absolute top-0 left-1/4 h-60 w-60 rounded-full bg-white/10 blur-3xl" style="animation: float-orb 8s ease-in-out infinite;"></div>
      <div class="absolute bottom-0 right-1/4 h-80 w-80 rounded-full bg-white/5 blur-3xl" style="animation: float-orb 10s ease-in-out infinite 1s;"></div>

      <div class="absolute inset-0 opacity-[0.05]" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 30px 30px;"></div>

      <div class="relative z-10">
        <div class="mx-auto mb-6 flex h-14 w-14 items-center justify-center rounded-2xl bg-white/10 backdrop-blur-sm">
          <svg class="h-7 w-7 text-primary-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" /></svg>
        </div>

        <h2 class="mb-4 font-heading text-4xl font-bold text-primary-foreground md:text-5xl">
          Prêt à booster votre<br />productivité avec l'IA ?
        </h2>
        <p class="mx-auto mb-10 max-w-lg text-primary-foreground/80 text-lg">
          Explorez notre catalogue complet d'outils IA, classés par catégorie et cas d'usage.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a
            href="#categories"
            class="inline-flex items-center justify-center rounded-full px-10 h-13 font-semibold text-base shadow-xl bg-secondary text-secondary-foreground"
          >
            Explorer les outils
            <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
          </a>
          <a
            href="#cas-usage"
            class="inline-flex items-center justify-center rounded-full border border-primary-foreground/20 px-10 h-13 text-primary-foreground hover:bg-primary-foreground/10 text-base"
          >
            Voir les cas d'usage
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
