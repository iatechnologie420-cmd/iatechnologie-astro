---
import { getCollection } from 'astro:content';

const casUsages = await getCollection('cas-usage');
---

<section id="cas-usage" class="relative py-24 overflow-hidden">
  <div class="absolute top-0 left-1/2 -translate-x-1/2 h-px w-3/4 bg-gradient-to-r from-transparent via-primary/30 to-transparent"></div>

  <div class="container relative z-10">
    <div class="mb-16 text-center ">
      <span class="mb-4 inline-block rounded-full bg-primary/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-primary">
        Cas d'usage
      </span>
      <h2 class="mb-4 font-heading text-4xl font-bold text-foreground md:text-5xl">
        L'IA adaptée à <span class="gradient-text">vos besoins</span>
      </h2>
      <p class="mx-auto max-w-xl text-muted-foreground">
        Que vous soyez créateur, développeur, marketeur ou étudiant,
        trouvez les outils IA faits pour vous.
      </p>
    </div>

    <div class="grid gap-4 grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
      {casUsages.map((cu, i) => (
        <a
          href={`/cas-usage/${cu.data.slug}`}
          class="group relative flex flex-col items-center text-center rounded-2xl glass-card p-6 transition-all duration-500 hover:border-primary/40 hover:shadow-xl hover:shadow-primary/10 hover:-translate-y-1.5 cursor-pointer overflow-hidden "
          style={`transition-delay: ${i * 0.04}s;`}
        >
          <div class="absolute inset-0 rounded-2xl bg-gradient-to-b from-primary/0 via-primary/0 to-primary/0 transition-all duration-700 group-hover:from-primary/5 group-hover:via-transparent group-hover:to-primary/5"></div>
          <div class="absolute top-0 left-1/2 -translate-x-1/2 w-0 h-[2px] bg-gradient-to-r from-primary to-primary-glow rounded-full transition-all duration-500 group-hover:w-3/4 group-hover:neon-line"></div>

          <div class="relative z-10 mb-4 flex h-16 w-16 items-center justify-center rounded-2xl bg-card border border-border/50 transition-all duration-500 group-hover:border-primary/30 group-hover:shadow-lg group-hover:shadow-primary/10">
            <span class="text-3xl transition-transform duration-500 group-hover:scale-110">
              {cu.data.icon}
            </span>
          </div>

          <h3 class="relative z-10 font-heading text-sm font-semibold text-foreground group-hover:text-primary transition-colors mb-2">
            {cu.data.name}
          </h3>

          {cu.data.description && (
            <p class="relative z-10 text-xs text-muted-foreground line-clamp-2 leading-relaxed mb-3">
              {cu.data.description}
            </p>
          )}

          <div class="relative z-10 mt-auto flex items-center gap-1 text-xs font-medium text-muted-foreground group-hover:text-primary transition-colors">
            <span>Explorer</span>
            <svg class="h-3 w-3 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
