---
const steps = [
  {
    number: '01',
    title: 'Explorez',
    description: "Parcourez 500+ outils IA triés par catégorie et cas d'usage. Notre moteur de recherche intelligent vous guide vers la solution idéale.",
    stat: '500+',
    statLabel: 'outils référencés',
    iconPath: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z',
    statIconPath: 'M13 10V3L4 14h7v7l9-11h-7z',
  },
  {
    number: '02',
    title: 'Comparez',
    description: "Fiches détaillées avec avis d'experts, comparatifs de prix, fonctionnalités clés et alternatives — tout ce qu'il faut pour choisir en confiance.",
    stat: '100%',
    statLabel: 'gratuit & sans inscription',
    iconPath: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
    statIconPath: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    number: '03',
    title: 'Lancez-vous',
    description: "Accédez directement à l'outil choisi et boostez votre productivité. Nos tutoriels YouTube vous accompagnent dans la prise en main.",
    stat: '30s',
    statLabel: 'pour trouver votre outil',
    iconPath: 'M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.63 8.09m5.96 6.28A7.49 7.49 0 003 3m17.94 9.37A7.49 7.49 0 003 21',
    statIconPath: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
  },
];
---

<section class="relative py-28 overflow-hidden">
  <div class="absolute inset-0 -z-10" style="background-image: radial-gradient(circle at 1px 1px, hsl(var(--primary) / 0.04) 1px, transparent 0); background-size: 48px 48px;"></div>
  <div class="absolute top-0 left-1/2 -translate-x-1/2 h-px w-3/4 bg-gradient-to-r from-transparent via-primary/30 to-transparent"></div>

  <div class="container relative z-10">
    <div class="mb-20 text-center animate-on-scroll">
      <span class="mb-4 inline-block rounded-full bg-primary/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-primary">Simple & rapide</span>
      <h2 class="mb-4 font-heading text-4xl font-bold text-foreground md:text-5xl">
        Comment ça <span class="gradient-text">marche ?</span>
      </h2>
      <p class="mx-auto max-w-2xl text-muted-foreground text-lg">
        Trouver l'outil IA parfait n'a jamais été aussi simple.<br class="hidden sm:block" />
        <span class="text-foreground font-medium">Trois étapes, zéro prise de tête.</span>
      </p>
    </div>

    <div class="grid gap-6 md:grid-cols-3">
      {steps.map((step, i) => (
        <div class="group relative animate-on-scroll" style={`transition-delay: ${i * 0.15}s;`}>
          <div class="relative overflow-hidden rounded-3xl glass-card p-8 transition-all duration-500 hover:border-primary/30 hover:shadow-2xl hover:shadow-primary/10 hover:-translate-y-2 h-full flex flex-col">
            <span class="absolute -top-4 -right-2 font-heading text-[120px] font-bold leading-none text-primary/[0.04] select-none">{step.number}</span>

            <div class="flex items-center gap-4 mb-6">
              <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br from-primary/20 to-primary-glow/10 text-primary ring-1 ring-primary/20">
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={step.iconPath} /></svg>
              </div>
              <div class="rounded-full bg-primary/10 px-3 py-1 text-xs font-bold text-primary">Étape {step.number}</div>
            </div>

            <h3 class="mb-3 font-heading text-2xl font-bold text-foreground group-hover:text-primary transition-colors">{step.title}</h3>
            <p class="text-sm leading-relaxed text-muted-foreground flex-1">{step.description}</p>

            <div class="mt-6 flex items-center gap-3 rounded-xl bg-primary/5 border border-primary/10 px-4 py-3">
              <svg class="h-5 w-5 text-primary shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={step.statIconPath} /></svg>
              <div>
                <span class="font-heading text-lg font-bold text-primary">{step.stat}</span>
                <span class="ml-2 text-xs text-muted-foreground">{step.statLabel}</span>
              </div>
            </div>
          </div>

          {i < steps.length - 1 && (
            <div class="absolute -right-3 top-1/2 z-20 hidden -translate-y-1/2 lg:block">
              <div class="flex h-8 w-8 items-center justify-center rounded-full bg-card border border-border text-primary">→</div>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
