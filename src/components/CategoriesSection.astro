---
import { getCollection } from 'astro:content';

const categories = await getCollection('categories');
const sorted = [...categories].sort((a, b) => b.data.count - a.data.count);
---

<section id="categories" class="relative py-24 noise-bg overflow-hidden">
  <div class="absolute top-20 -left-32 w-64 h-64 rounded-full bg-primary/5 blur-3xl"></div>
  <div class="absolute bottom-20 -right-32 w-64 h-64 rounded-full bg-accent/5 blur-3xl"></div>

  <div class="container relative z-10">
    <div class="mb-16 text-center animate-on-scroll">
      <span class="mb-4 inline-block rounded-full bg-primary/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-primary">
        Catégories
      </span>
      <h2 class="mb-4 font-heading text-4xl font-bold text-foreground md:text-5xl">
        Explorez par <span class="gradient-text">catégorie</span>
      </h2>
      <p class="mx-auto max-w-xl text-muted-foreground">
        Les meilleures solutions IA classées par domaine d'expertise.
      </p>
    </div>

    <div class="flex flex-wrap justify-center gap-3 md:gap-4 max-w-4xl mx-auto">
      {sorted.map((cat, i) => (
        <a
          href={`/categorie/${cat.data.slug}`}
          class="group relative flex items-center gap-3 rounded-full bg-card/80 ring-1 ring-border/50 hover:ring-primary/40 hover:shadow-primary/10 backdrop-blur-sm px-5 py-3 md:px-6 md:py-4 transition-all duration-500 hover:shadow-lg hover:scale-[1.08] hover:-translate-y-1 cursor-pointer animate-on-scroll"
          style={`transition-delay: ${i * 0.05}s;`}
        >
          <span class="text-xl md:text-2xl transition-transform duration-300 group-hover:scale-125 group-hover:rotate-12">
            {cat.data.icon}
          </span>
          <span class="font-heading text-sm md:text-base font-semibold text-foreground group-hover:text-primary transition-colors whitespace-nowrap">
            {cat.data.name}
          </span>
          {cat.data.count > 0 && (
            <span class="ml-1 rounded-full bg-primary/15 px-2 py-0.5 text-[10px] font-bold text-primary">
              {cat.data.count}
            </span>
          )}
        </a>
      ))}
    </div>
  </div>
</section>
