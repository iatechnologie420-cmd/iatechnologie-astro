---
import youtubeData from '@/data/youtube-videos.json';

const subscriberCount = youtubeData.subscriberCount || 6218;

const formatCount = (count: number) => {
  if (count >= 1_000_000) return `${(count / 1_000_000).toFixed(1)}M`;
  if (count >= 1_000) return `${Math.floor(count / 1_000)}k+`;
  return count.toString();
};
---

<section class="relative flex pt-8 pb-4 overflow-x-clip">
  <!-- Floating orbs -->
  <div class="absolute top-10 right-[10%] h-80 w-80 rounded-full blur-3xl bg-primary/15" style="animation: float-orb 12s ease-in-out infinite;"></div>
  <div class="absolute bottom-10 left-[5%] h-96 w-96 rounded-full blur-3xl bg-accent/10" style="animation: float-orb 12s ease-in-out infinite 2s;"></div>
  <div class="absolute top-1/2 left-1/2 h-64 w-64 rounded-full blur-3xl bg-primary-glow/10" style="animation: float-orb 12s ease-in-out infinite 4s;"></div>

  <!-- Dot grid background -->
  <div class="absolute inset-0 -z-10" style="background-image: radial-gradient(circle at 1px 1px, hsl(var(--primary) / 0.07) 1px, transparent 0); background-size: 40px 40px;"></div>

  <div class="container relative z-10 max-w-6xl py-6">
    <div class="flex flex-col items-center">
      <div class="text-center">
        <!-- Badge -->
        <div class="mb-6 inline-flex items-center gap-3 rounded-full glass border-primary/20 px-5 py-1.5 shadow-xl shadow-primary/10 group hover:border-primary/40 transition-all duration-700">
          <div class="relative flex items-center justify-center">
            <span class="animate-ping absolute inline-flex h-3 w-3 rounded-full bg-accent/30"></span>
            <svg class="relative h-4 w-4 text-accent drop-shadow-[0_0_8px_rgba(var(--accent-rgb),0.5)] transition-transform group-hover:scale-110 duration-700" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l1.5 4.5L18 8l-4.5 1.5L12 14l-1.5-4.5L6 8l4.5-1.5L12 2zm8 10l.75 2.25L23 15l-2.25.75L20 18l-.75-2.25L17 15l2.25-.75L20 12zm-12 5l.5 1.5L10 19l-1.5.5L8 21l-.5-1.5L6 19l1.5-.5L8 17z"/></svg>
          </div>
          <span class="text-[10px] font-bold uppercase tracking-[0.2em] bg-gradient-to-r from-foreground/60 via-foreground to-foreground/60 bg-clip-text text-transparent animate-shimmer bg-[length:200%_auto] whitespace-nowrap">
            Mise à jour quotidienne
          </span>
        </div>

        <!-- Heading -->
        <h1 class="mb-6 font-heading text-4xl font-bold leading-[1.15] tracking-tight text-foreground sm:text-5xl md:text-6xl lg:text-7xl animate-in fade-in slide-in-from-bottom-8 duration-1000 fill-mode-both" style="transition-delay: 0.2s;">
          L'annuaire des meilleurs <br />
          <span class="text-gradient-shine">outils IA de 2026</span>
        </h1>

        <!-- Subheading -->
        <p class="mx-auto mb-6 max-w-2xl text-base text-muted-foreground sm:text-lg md:text-xl leading-relaxed animate-in fade-in slide-in-from-bottom-6 duration-1000 delay-200 fill-mode-both" style="transition-delay: 0.4s;">
          L'IA passée au crible. Plus de <span class="font-semibold text-foreground/90">500 outils IA</span> analysés minutieusement pour vous livrer la vérité sur leurs prix et performances.<br class="hidden md:block" />
          Trouvez l'outil idéal pour vos projets en <span class="font-semibold text-foreground/90">30 secondes</span>.
        </p>

      </div>
    </div>
  </div>
</section>


