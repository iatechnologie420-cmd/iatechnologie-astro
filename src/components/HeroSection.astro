---
import youtubeData from '@/data/youtube-videos.json';

const subscriberCount = youtubeData.subscriberCount || 6218;

const formatCount = (count: number) => {
  if (count >= 1_000_000) return `${(count / 1_000_000).toFixed(1)}M`;
  if (count >= 1_000) return `${Math.floor(count / 1_000)}k+`;
  return count.toString();
};

const today = new Date();
const dayNames = ['Dimanche', 'Lundi', 'Mardi', 'Mercredi', 'Jeudi', 'Vendredi', 'Samedi'];
const monthNames = ['janvier', 'février', 'mars', 'avril', 'mai', 'juin', 'juillet', 'août', 'septembre', 'octobre', 'novembre', 'décembre'];
const formattedDate = `${dayNames[today.getDay()]} ${today.getDate()} ${monthNames[today.getMonth()]} ${today.getFullYear()}`;
---

<section class="relative flex pt-8 overflow-x-clip">
  <!-- Floating orbs -->
  <div class="absolute top-10 right-[10%] h-80 w-80 rounded-full blur-3xl bg-primary/15" style="animation: float-orb 12s ease-in-out infinite;"></div>
  <div class="absolute bottom-10 left-[5%] h-96 w-96 rounded-full blur-3xl bg-accent/10" style="animation: float-orb 12s ease-in-out infinite 2s;"></div>
  <div class="absolute top-1/2 left-1/2 h-64 w-64 rounded-full blur-3xl bg-primary-glow/10" style="animation: float-orb 12s ease-in-out infinite 4s;"></div>

  <!-- Dot grid background -->
  <div class="absolute inset-0 -z-10" style="background-image: radial-gradient(circle at 1px 1px, hsl(var(--primary) / 0.07) 1px, transparent 0); background-size: 40px 40px;"></div>

  <div class="container relative z-10 max-w-6xl py-6">
    <div class="flex flex-col items-center">
      <div class="text-center">
        <!-- Live badge -->
        <div class="mb-6 inline-flex items-center gap-3 rounded-full glass border-primary/20 px-5 py-1.5 shadow-xl shadow-primary/10 group hover:border-primary/40 transition-all duration-700">
          <div class="relative flex items-center justify-center">
            <span class="animate-ping absolute inline-flex h-2.5 w-2.5 rounded-full bg-emerald-500/40"></span>
            <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-emerald-500"></span>
          </div>
          <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-muted-foreground whitespace-nowrap">
            Mis à jour — {formattedDate}
          </span>
        </div>

        <!-- Heading -->
        <h1 class="mb-6 font-heading text-4xl font-extrabold leading-[1.1] tracking-tight text-foreground sm:text-5xl md:text-6xl lg:text-7xl animate-in fade-in slide-in-from-bottom-8 duration-1000 fill-mode-both" style="transition-delay: 0.2s;">
          L'annuaire des meilleurs <br />
          <span class="text-gradient-shine">outils IA de 2026</span>
        </h1>

        <!-- Subheading -->
        <p class="mx-auto mb-8 max-w-2xl text-base text-muted-foreground sm:text-lg md:text-xl leading-relaxed animate-in fade-in slide-in-from-bottom-6 duration-1000 delay-200 fill-mode-both" style="transition-delay: 0.4s;">
          L'IA passée au crible. Plus de <span class="font-semibold text-foreground/90">500 outils IA</span> analysés minutieusement pour vous livrer la vérité sur leurs prix et performances.<br class="hidden md:block" />
          Trouvez l'outil idéal pour vos projets en <span class="font-semibold text-foreground/90">30 secondes</span>.
        </p>

        <!-- CTA: Newsletter FIRST, Explorer second -->
        <div class="mx-auto max-w-lg animate-in fade-in slide-in-from-bottom-4 duration-1000 delay-300 fill-mode-both" style="transition-delay: 0.6s;">
          <!-- Email capture inline -->
          <form 
            id="hero-newsletter-form" 
            action="https://a9004679.sibforms.com/serve/MUIFACbRWtBQ58ZmHzft3_TYeb6dgjn8pxrvkPC4295ca3r6HbKwB6l48zrrXllACuSgL9wreMo-NLKumsoeeGZuh7cMZpAXoRPqk00rvRE8kb5AM5-Hq3QfTxNBvuOo-u15nR0Ir-rqLA3HAyb8X8h8pkvDgfdhzkf85zkwp3R2LJ4mKXqeZD-dpkrLcAqIMmq0uxaHh2JxaESzPQ=="
            method="POST"
            class="flex flex-col sm:flex-row gap-3 sm:gap-0 sm:p-1.5 sm:rounded-full sm:border sm:border-border/50 sm:bg-card/50 sm:backdrop-blur-sm sm:shadow-lg sm:shadow-primary/5 transition-all"
          >
            <input 
              type="email" 
              name="EMAIL"
              placeholder="votre@email.com" 
              class="w-full flex-1 rounded-full border border-border/50 sm:border-0 bg-card/50 sm:bg-transparent px-6 py-3.5 text-base text-foreground placeholder-muted-foreground/60 focus:outline-none focus:ring-2 focus:ring-primary/30 sm:focus:ring-0"
              required
              id="hero-email-input"
            />
            <input type="text" name="email_address_check" value="" class="hidden" aria-hidden="true" />
            <input type="hidden" name="locale" value="fr" />
            <button 
              type="submit" 
              class="inline-flex items-center justify-center rounded-full bg-primary px-8 py-3.5 text-base font-bold text-primary-foreground shadow-lg shadow-primary/25 transition-all hover:scale-105 hover:bg-primary/90 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 focus:ring-offset-background whitespace-nowrap"
            >
              Recevoir la sélection
            </button>
          </form>
          
          <!-- Message de succès (caché par défaut) -->
          <div id="hero-success-message" class="hidden py-3 px-6 rounded-full bg-primary/10 border border-primary/20 text-primary font-bold animate-in zoom-in duration-300">
            ✅ C'est noté ! Surveillez votre boîte mail.
          </div>

          <p id="hero-disclaimer" class="mt-3 text-xs text-muted-foreground/60 text-center">
            Chaque jeudi. Gratuit. Désinscription en 1 clic.
          </p>
        </div>

        <!-- Secondary CTA -->
        <div class="mt-6 animate-in fade-in duration-1000 delay-500 fill-mode-both" style="transition-delay: 0.8s;">
          <a href="#tools-explorer" class="inline-flex items-center gap-2 text-sm font-medium text-muted-foreground hover:text-primary transition-colors group">
            Explorer les 500+ outils
            <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
          </a>
        </div>

        <!-- Social proof bar -->
        <div class="mt-10 flex flex-wrap items-center justify-center gap-6 sm:gap-10 text-sm text-muted-foreground animate-in fade-in duration-1000 delay-700 fill-mode-both" style="transition-delay: 1s;">
          <div class="flex items-center gap-2">
            <svg class="h-4 w-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            <span><span class="font-semibold text-foreground">10 400+</span> abonnés</span>
          </div>
          <div class="h-4 w-px bg-border/50 hidden sm:block"></div>
          <div class="flex items-center gap-2">
            <svg class="h-4 w-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
            <span><span class="font-semibold text-foreground">534</span> outils testés</span>
          </div>
          <div class="h-4 w-px bg-border/50 hidden sm:block"></div>
          <div class="flex items-center gap-2">
            <svg class="h-4 w-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
            <span>Mise à jour <span class="font-semibold text-foreground">quotidienne</span></span>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<script>
  const heroForm = document.getElementById('hero-newsletter-form') as HTMLFormElement;
  const heroSuccess = document.getElementById('hero-success-message');
  const heroDisclaimer = document.getElementById('hero-disclaimer');

  heroForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    // Envoi en arrière-plan vers Brevo
    const formData = new FormData(heroForm);
    
    try {
      fetch(heroForm.action, {
        method: 'POST',
        body: formData,
        mode: 'no-cors'
      });

      // Succès visuel immédiat
      heroForm.classList.add('hidden');
      heroDisclaimer?.classList.add('hidden');
      heroSuccess?.classList.remove('hidden');
    } catch (err) {
      console.error('Erreur:', err);
      heroForm.classList.add('hidden');
      heroDisclaimer?.classList.add('hidden');
      heroSuccess?.classList.remove('hidden');
    }
  });
</script>
