---
import youtubeData from '@/data/youtube-videos.json';

const subscriberCount = youtubeData.subscriberCount || 6218;

const formatCount = (count: number) => {
  if (count >= 1_000_000) return `${(count / 1_000_000).toFixed(1)}M`;
  if (count >= 1_000) return `${Math.floor(count / 1_000)}k+`;
  return count.toString();
};
---

<section class="relative flex min-h-[80vh] items-center overflow-hidden">
  <!-- Floating orbs -->
  <div class="absolute top-10 right-[10%] h-80 w-80 rounded-full blur-3xl bg-primary/15" style="animation: float-orb 12s ease-in-out infinite;"></div>
  <div class="absolute bottom-10 left-[5%] h-96 w-96 rounded-full blur-3xl bg-accent/10" style="animation: float-orb 12s ease-in-out infinite 2s;"></div>
  <div class="absolute top-1/2 left-1/2 h-64 w-64 rounded-full blur-3xl bg-primary-glow/10" style="animation: float-orb 12s ease-in-out infinite 4s;"></div>

  <!-- Dot grid background -->
  <div class="absolute inset-0 -z-10" style="background-image: radial-gradient(circle at 1px 1px, hsl(var(--primary) / 0.07) 1px, transparent 0); background-size: 40px 40px;"></div>

  <div class="container relative z-10 max-w-6xl py-16">
    <div class="flex flex-col items-center">
      <div class="text-center">
        <!-- Badge -->
        <div class="mb-6 inline-flex items-center gap-2 rounded-full glass border-border/40 px-4 py-1.5 shadow-lg shadow-red-500/5">
          <span class="relative flex h-2.5 w-2.5">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-500 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-red-500"></span>
          </span>
          <span class="text-[11px] font-bold uppercase tracking-[0.1em] text-foreground/90">
            Mise à jour en direct chaque jour
          </span>
        </div>

        <!-- Heading -->
        <h1 class="mb-6 font-heading text-4xl font-bold leading-[1.15] tracking-tight text-foreground sm:text-5xl md:text-6xl lg:text-7xl animate-in fade-in slide-in-from-bottom-8 duration-1000 fill-mode-both" style="transition-delay: 0.2s;">
          L'annuaire des meilleurs <br />
          <span class="text-gradient-shine">outils IA de 2026</span>
        </h1>

        <!-- Subheading -->
        <p class="mx-auto mb-10 max-w-2xl text-base text-muted-foreground sm:text-lg md:text-xl leading-relaxed animate-in fade-in slide-in-from-bottom-6 duration-1000 delay-200 fill-mode-both" style="transition-delay: 0.4s;">
          L'IA passée au crible. Plus de 500 outils analysés sans blabla marketing pour vous livrer la vérité sur leurs prix et performances.
        </p>

        <!-- Search bar -->
        <div class="relative mx-auto max-w-2xl animate-in fade-in slide-in-from-bottom-4 duration-1000 delay-300 fill-mode-both" style="transition-delay: 0.5s;" id="hero-search-container">
          <div class="relative group">
            <div class="absolute -inset-1 rounded-2xl bg-gradient-to-r from-primary/30 via-accent/20 to-primary/30 opacity-0 blur-xl transition-all duration-700 group-focus-within:opacity-100"></div>
            <div class="relative">
              <svg class="absolute left-5 top-1/2 h-5 w-5 -translate-y-1/2 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
              <input
                type="search"
                id="hero-search-input"
                aria-label="Rechercher un outil IA"
                placeholder="Quel outil recherchez-vous ? (ex: ChatGPT, Midjourney...)"
                class="h-16 w-full rounded-2xl border border-border/50 bg-card/60 backdrop-blur-md pl-14 pr-5 text-lg text-foreground placeholder:text-muted-foreground/60 shadow-2xl shadow-primary/5 transition-all focus:bg-card/90 focus:border-primary/40 focus:outline-none focus:ring-0"
              />
            </div>
          </div>

          <!-- Search results dropdown -->
          <div id="hero-search-results" class="absolute left-0 right-0 top-full z-50 mt-2 overflow-hidden rounded-2xl glass-card shadow-2xl hidden"></div>
        </div>

        <!-- CTA buttons -->
        <div class="mt-7 flex flex-wrap items-center justify-center gap-4 " style="transition-delay: 0.6s;">
          <a
            href="#categories"
            class="inline-flex items-center justify-center rounded-full px-8 h-12 font-semibold bg-primary text-primary-foreground glow-sm hover:glow-md transition-shadow"
          >
            Explorer les outils
            <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
          </a>
          <a
            href="#cas-usage"
            class="inline-flex items-center justify-center rounded-full px-8 h-12 glass"
          >
            Voir les cas d'usage
          </a>
        </div>
      </div>
    </div>

    <!-- Stats -->
    <div class="mt-20 grid grid-cols-2 gap-8 md:flex md:items-center md:justify-center md:gap-16 lg:gap-24 animate-in fade-in slide-in-from-bottom-4 duration-1000 delay-500 fill-mode-both" style="transition-delay: 1s;">
      <div class="flex items-center gap-4 group">
        <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-primary/10 text-primary transition-transform group-hover:scale-110 group-hover:bg-primary/20">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
        </div>
        <div>
          <div class="font-heading text-2xl font-bold text-foreground">500+</div>
          <div class="text-[10px] font-bold uppercase tracking-widest text-muted-foreground/60">Outils</div>
        </div>
      </div>
      <div class="flex items-center gap-4 group">
        <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-accent/10 text-accent transition-transform group-hover:scale-110 group-hover:bg-accent/20">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>
        </div>
        <div>
          <div class="font-heading text-2xl font-bold text-foreground">18</div>
          <div class="text-[10px] font-bold uppercase tracking-widest text-muted-foreground/60">Catégories</div>
        </div>
      </div>
      <div class="flex items-center gap-4 group">
        <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-primary/10 text-primary transition-transform group-hover:scale-110 group-hover:bg-primary/20">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z" /></svg>
        </div>
        <div>
          <div class="font-heading text-2xl font-bold text-foreground">10k+</div>
          <div class="text-[10px] font-bold uppercase tracking-widest text-muted-foreground/60">Visiteurs / mois</div>
        </div>
      </div>
      <div class="flex items-center gap-4 group">
        <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-red-500/10 text-red-500 transition-transform group-hover:scale-110 group-hover:bg-red-500/20">
          <svg class="h-6 w-6 fill-current" viewBox="0 0 24 24"><path d="M8 5v14l11-7z" /></svg>
        </div>
        <div>
          <div class="font-heading text-2xl font-bold text-foreground">{formatCount(subscriberCount)}</div>
          <div class="text-[10px] font-bold uppercase tracking-widest text-muted-foreground/60">YouTube</div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Client-side search with static data
  const input = document.getElementById('hero-search-input') as HTMLInputElement;
  const resultsEl = document.getElementById('hero-search-results');

  // The search will work once content is imported — for now it searches page titles
  let searchTimeout: ReturnType<typeof setTimeout>;

  input?.addEventListener('input', () => {
    clearTimeout(searchTimeout);
    const q = input.value.trim();
    if (q.length < 2) {
      resultsEl?.classList.add('hidden');
      return;
    }
    // Static search: find all tool links on the page
    searchTimeout = setTimeout(() => {
      const allLinks = document.querySelectorAll('a[href^="/outil/"]');
      const matches: { href: string; text: string }[] = [];
      allLinks.forEach((a) => {
        const text = a.textContent?.trim() || '';
        if (text.toLowerCase().includes(q.toLowerCase())) {
          matches.push({ href: (a as HTMLAnchorElement).href, text });
        }
      });
      if (matches.length > 0 && resultsEl) {
        resultsEl.innerHTML = matches
          .slice(0, 8)
          .map((m) => `<a href="${m.href}" class="flex w-full items-center gap-3 px-5 py-3 text-left transition-all hover:bg-primary/5"><div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-sm font-medium text-primary">🔧</div><div class="flex-1 min-w-0"><div class="font-medium text-foreground text-sm">${m.text}</div></div></a>`)
          .join('');
        resultsEl.classList.remove('hidden');
      } else {
        if (resultsEl) {
          resultsEl.innerHTML = `<div class="p-6 text-center text-sm text-muted-foreground">Aucun outil trouvé pour "${q}"</div>`;
          resultsEl.classList.remove('hidden');
        }
      }
    }, 200);
  });

  // Close on click outside
  document.addEventListener('click', (e) => {
    const container = document.getElementById('hero-search-container');
    if (container && !container.contains(e.target as Node)) {
      resultsEl?.classList.add('hidden');
    }
  });
</script>
