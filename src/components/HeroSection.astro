---
import youtubeData from '@/data/youtube-videos.json';

const subscriberCount = youtubeData.subscriberCount || 6218;

const formatCount = (count: number) => {
  if (count >= 1_000_000) return `${(count / 1_000_000).toFixed(1)}M`;
  if (count >= 1_000) return `${Math.floor(count / 1_000)}k+`;
  return count.toString();
};
---

<section class="relative flex min-h-[80vh] items-center overflow-hidden">
  <!-- Floating orbs -->
  <div class="absolute top-10 right-[10%] h-80 w-80 rounded-full blur-3xl bg-primary/15" style="animation: float-orb 12s ease-in-out infinite;"></div>
  <div class="absolute bottom-10 left-[5%] h-96 w-96 rounded-full blur-3xl bg-accent/10" style="animation: float-orb 12s ease-in-out infinite 2s;"></div>
  <div class="absolute top-1/2 left-1/2 h-64 w-64 rounded-full blur-3xl bg-primary-glow/10" style="animation: float-orb 12s ease-in-out infinite 4s;"></div>

  <!-- Dot grid background -->
  <div class="absolute inset-0 -z-10" style="background-image: radial-gradient(circle at 1px 1px, hsl(var(--primary) / 0.07) 1px, transparent 0); background-size: 40px 40px;"></div>

  <div class="container relative z-10 max-w-6xl py-16">
    <div class="flex flex-col items-center">
      <div class="text-center">
        <!-- Badge -->
        <div class="mb-6 inline-flex items-center gap-2 rounded-full glass px-5 py-2 ">
          <svg class="h-4 w-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" /></svg>
          <span class="text-sm font-medium text-foreground">
            L'annuaire #1 des meilleurs outils IA
          </span>
        </div>

        <!-- Heading -->
        <h1 class="mb-5 font-heading text-4xl font-bold leading-[1.1] tracking-tight text-foreground sm:text-5xl md:text-6xl lg:text-7xl " style="transition-delay: 0.2s;">
          Les meilleurs outils IA
          <br />
          <span class="text-gradient-shine">de 2026</span>
        </h1>

        <!-- Subheading -->
        <p class="mx-auto mb-8 max-w-2xl text-base text-muted-foreground sm:text-lg md:text-xl leading-relaxed " style="transition-delay: 0.4s;">
          Trouvez l'outil parfait en 30 secondes — comparatif, avis d'experts et guide complet.
        </p>

        <!-- Search bar -->
        <div class="relative mx-auto max-w-2xl " style="transition-delay: 0.5s;" id="hero-search-container">
          <div class="relative group">
            <div class="absolute -inset-1 rounded-2xl bg-gradient-to-r from-primary/20 via-accent/15 to-primary/20 opacity-0 blur-lg transition-opacity duration-500 group-focus-within:opacity-100"></div>
            <div class="relative">
              <svg class="absolute left-5 top-1/2 h-5 w-5 -translate-y-1/2 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
              <input
                type="search"
                id="hero-search-input"
                placeholder="Rechercher un outil IA... (ex: ChatGPT, Midjourney)"
                class="h-14 w-full rounded-2xl border border-border/50 bg-card/80 backdrop-blur-sm pl-14 pr-5 text-base text-foreground placeholder:text-muted-foreground shadow-xl shadow-primary/5 transition-all focus:shadow-2xl focus:shadow-primary/10 focus:border-primary/30 focus:outline-none focus:ring-0"
              />
            </div>
          </div>

          <!-- Search results dropdown -->
          <div id="hero-search-results" class="absolute left-0 right-0 top-full z-50 mt-2 overflow-hidden rounded-2xl glass-card shadow-2xl hidden"></div>
        </div>

        <!-- CTA buttons -->
        <div class="mt-7 flex flex-wrap items-center justify-center gap-4 " style="transition-delay: 0.6s;">
          <a
            href="#categories"
            class="inline-flex items-center justify-center rounded-full px-8 h-12 font-semibold bg-primary text-primary-foreground glow-sm hover:glow-md transition-shadow"
          >
            Explorer les outils
            <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
          </a>
          <a
            href="#cas-usage"
            class="inline-flex items-center justify-center rounded-full px-8 h-12 glass"
          >
            Voir les cas d'usage
          </a>
        </div>
      </div>
    </div>

    <!-- Stats -->
    <div class="mt-12 flex flex-wrap items-center justify-center gap-8 md:gap-12 " style="transition-delay: 1s;">
      <div class="flex items-center gap-3">
        <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-primary/10 text-primary">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
        </div>
        <div>
          <div class="font-heading text-xl font-bold text-foreground">500+</div>
          <div class="text-xs text-muted-foreground">Outils référencés</div>
        </div>
        <div class="ml-4 hidden h-8 w-px bg-border md:block"></div>
      </div>
      <div class="flex items-center gap-3">
        <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-primary/10 text-primary">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>
        </div>
        <div>
          <div class="font-heading text-xl font-bold text-foreground">18</div>
          <div class="text-xs text-muted-foreground">Catégories</div>
        </div>
        <div class="ml-4 hidden h-8 w-px bg-border md:block"></div>
      </div>
      <div class="flex items-center gap-3">
        <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-primary/10 text-primary">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z" /></svg>
        </div>
        <div>
          <div class="font-heading text-xl font-bold text-foreground">10k+</div>
          <div class="text-xs text-muted-foreground">Visiteurs / mois</div>
        </div>
        <div class="ml-4 hidden h-8 w-px bg-border md:block"></div>
      </div>
      <div class="flex items-center gap-3">
        <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-[hsl(0,100%,50%)]/10 text-[hsl(0,100%,50%)]">
          <svg class="h-5 w-5 fill-current" viewBox="0 0 24 24"><path d="M8 5v14l11-7z" /></svg>
        </div>
        <div>
          <div class="font-heading text-xl font-bold text-foreground">{formatCount(subscriberCount)}</div>
          <div class="text-xs text-muted-foreground">Abonnés YouTube</div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Client-side search with static data
  const input = document.getElementById('hero-search-input') as HTMLInputElement;
  const resultsEl = document.getElementById('hero-search-results');

  // The search will work once content is imported — for now it searches page titles
  let searchTimeout: ReturnType<typeof setTimeout>;

  input?.addEventListener('input', () => {
    clearTimeout(searchTimeout);
    const q = input.value.trim();
    if (q.length < 2) {
      resultsEl?.classList.add('hidden');
      return;
    }
    // Static search: find all tool links on the page
    searchTimeout = setTimeout(() => {
      const allLinks = document.querySelectorAll('a[href^="/outil/"]');
      const matches: { href: string; text: string }[] = [];
      allLinks.forEach((a) => {
        const text = a.textContent?.trim() || '';
        if (text.toLowerCase().includes(q.toLowerCase())) {
          matches.push({ href: (a as HTMLAnchorElement).href, text });
        }
      });
      if (matches.length > 0 && resultsEl) {
        resultsEl.innerHTML = matches
          .slice(0, 8)
          .map((m) => `<a href="${m.href}" class="flex w-full items-center gap-3 px-5 py-3 text-left transition-all hover:bg-primary/5"><div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-sm font-medium text-primary">🔧</div><div class="flex-1 min-w-0"><div class="font-medium text-foreground text-sm">${m.text}</div></div></a>`)
          .join('');
        resultsEl.classList.remove('hidden');
      } else {
        if (resultsEl) {
          resultsEl.innerHTML = `<div class="p-6 text-center text-sm text-muted-foreground">Aucun outil trouvé pour "${q}"</div>`;
          resultsEl.classList.remove('hidden');
        }
      }
    }, 200);
  });

  // Close on click outside
  document.addEventListener('click', (e) => {
    const container = document.getElementById('hero-search-container');
    if (container && !container.contains(e.target as Node)) {
      resultsEl?.classList.add('hidden');
    }
  });
</script>
