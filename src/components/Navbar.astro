---
const navLinks = [
  { label: 'Catégories', href: '/categories' },
  { label: 'Le Blog', href: '/blog' },
  { label: 'Newsletter', href: '/newsletter' },
];
---

<header
  id="main-navbar"
  class="sticky top-0 z-50 transition-all duration-500 bg-transparent"
>
  <div class="container flex h-16 items-center justify-between">
    <a
      href="/"
      class="font-heading text-xl font-bold tracking-wider text-foreground hover:text-primary transition-colors pl-12 lg:pl-0"
    >
      <span class="gradient-text">IA</span> TECHNOLOGIE
    </a>

    <nav class="hidden items-center gap-1 md:flex">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="relative px-4 py-2 text-sm text-muted-foreground transition-colors hover:text-foreground group"
        >
          {link.label}
          <span class="absolute bottom-0 left-1/2 h-0.5 w-0 bg-primary transition-all duration-300 group-hover:left-1/4 group-hover:w-1/2 rounded-full" />
        </a>
      ))}
    </nav>

    <div class="hidden items-center gap-3 md:flex">
      <button aria-label="Recherche intelligente" class="p-2 text-muted-foreground hover:text-foreground transition-colors hover:bg-card/50 rounded-full border border-transparent hover:border-border/50">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      </button>
      <a
        href="/#directory"
        class="inline-flex items-center justify-center rounded-full px-6 h-9 text-sm font-medium bg-primary text-primary-foreground glow-sm hover:glow-md transition-shadow"
      >
        Explorer
      </a>
    </div>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden inline-flex items-center justify-center rounded-md p-2 text-muted-foreground hover:text-foreground"
      aria-label="Menu"
    >
      <svg id="menu-icon" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="close-icon" class="h-6 w-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div 
    id="mobile-menu" 
    class="fixed inset-0 top-16 z-50 bg-background/60 backdrop-blur-xl translate-x-full transition-transform duration-500 ease-out md:hidden"
  >
    <nav class="container flex flex-col gap-2 py-8">
      {navLinks.map((link, i) => (
        <a
          href={link.href}
          class="flex items-center justify-between rounded-2xl border border-border/50 bg-card/40 p-5 text-lg font-medium text-foreground transition-all active:scale-95"
          style={`transition-delay: ${i * 50}ms`}
        >
          {link.label}
          <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      ))}
      <a
        href="/#directory"
        class="mt-4 inline-flex items-center justify-center rounded-2xl bg-primary px-8 h-14 text-lg font-bold text-primary-foreground shadow-xl shadow-primary/20"
      >
        Explorer l'annuaire
      </a>
    </nav>
  </div>
</header>

<script>
  // Scroll effect
  const navbar = document.getElementById('main-navbar');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      navbar?.classList.add('glass', 'border-b', 'border-border/50', 'shadow-lg', 'shadow-background/50');
      navbar?.classList.remove('bg-transparent');
    } else {
      navbar?.classList.remove('glass', 'border-b', 'border-border/50', 'shadow-lg', 'shadow-background/50');
      navbar?.classList.add('bg-transparent');
    }
  }, { passive: true });

  // Mobile menu toggle
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('translate-x-full');
    
    if (isOpen) {
      menu?.classList.add('translate-x-full');
      document.body.style.overflow = '';
    } else {
      menu?.classList.remove('translate-x-full');
      document.body.style.overflow = 'hidden';
    }
    
    menuIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
  });

  // Close menu on link click
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu?.classList.add('translate-x-full');
      document.body.style.overflow = '';
      menuIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
    });
  });
</script>
