---
// Composant Central "Dashboard" (Remplace UseCases et Categories)
// Combine la navigation latérale (Sidebar) et les onglets de filtrage (Top Tabs)

const popularCategories = [
  { label: 'Growth & Marketing', icon: '📈', href: '/categorie/marketing' },
  { label: 'Rédaction & Contenu', icon: '✍️', href: '/categorie/texte' },
  { label: 'Chatbot & Assistants', icon: '💬', href: '/categorie/chatbot' },
  { label: 'Code & Développement', icon: '💻', href: '/categorie/code' },
  { label: 'Design & Créatif', icon: '🎨', href: '/categorie/design' },
  { label: 'Vidéo & Image', icon: '🎬', href: '/categorie/video' },
  { label: 'Productivité', icon: '⚡', href: '/categorie/productivite' },
  { label: 'SEO & Référencement', icon: '🔍', href: '/categorie/marketing' },
];

const allCategories = [
  { label: 'Assistant IA', icon: '🤖', href: '/categorie/assistant' },
  { label: 'Audio & Voix', icon: '🔊', href: '/categorie/audio' },
  { label: 'Automatisation', icon: '⚙️', href: '/categorie/automatisation' },
  { label: 'Analyse de données', icon: '📊', href: '/categorie/data' },
  { label: 'E-commerce', icon: '🛒', href: '/categorie/ecommerce' },
  { label: 'Email & Comm.', icon: '📧', href: '/categorie/email' },
  { label: 'Génération d\'images', icon: '🖼️', href: '/categorie/images' },
  { label: 'Podcast', icon: '🎙️', href: '/categorie/podcast' },
  { label: 'Copywriting', icon: '📝', href: '/categorie/copywriting' },
  { label: 'Réseaux sociaux', icon: '📱', href: '/categorie/social' },
  { label: 'Musique', icon: '🎵', href: '/categorie/musique' },
  { label: 'Montage vidéo', icon: '🎬', href: '/categorie/video' },
  { label: 'Storytelling', icon: '💡', href: '/categorie/storytelling' },
  { label: 'Présentation', icon: '📋', href: '/categorie/presentation' },
  { label: 'Prise de notes', icon: '📒', href: '/categorie/notes' },
];

// Définit quel onglet est actif par défaut
const { activeTab = 'populaires' } = Astro.props;

// Configuration des Onglets (SEO Silos)
const tabs = [
  { id: 'populaires', label: '🔥 Outils populaires', href: '/' },
  { id: 'nouveaux', label: '✨ Nouveaux outils', href: '/nouveaux-outils-ia' },
  { id: 'gratuits', label: '💸 Gratuits', href: '/outils-ia-gratuits' },
  { id: 'cas-usage', label: '🎯 Cas d\'usage', href: '/cas-usage' },
];
---

<section id="directory" class="relative py-16 bg-background">
  <div class="container max-w-7xl">
    
    <div class="flex flex-col lg:flex-row gap-8">
      
      <!-- COLONNE GAUCHE (30%) : LA SIDEBAR -->
      <aside class="w-full lg:w-[280px] shrink-0 flex flex-col gap-8 hidden lg:flex sticky top-24 max-h-[calc(100vh-6rem)] relative">
        <h2 class="sr-only">Exploration par Catégories</h2>
        
        <!-- Bloc 1 : Les plus populaires (Style Futurepedia) -->
        <div class="space-y-3">
          <h3 class="text-xs font-bold tracking-widest text-primary uppercase ml-1">Les + Populaires</h3>
          <nav class="flex flex-col gap-1">
            {popularCategories.map(item => (
              <a 
                href={item.href} 
                class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium text-muted-foreground hover:bg-card/80 hover:text-foreground transition-colors border border-transparent hover:border-border/50"
              >
                <span class="text-lg leading-none">{item.icon}</span>
                <span>{item.label}</span>
              </a>
            ))}
          </nav>
        </div>

        <!-- Bloc 2 : Toutes les catégories (Style LaCreme) -->
        <div class="space-y-3 flex-1 flex flex-col min-h-0">
          <h3 class="text-xs font-bold tracking-widest text-primary uppercase ml-1">Toutes les catégories</h3>
          <nav class="flex-1 overflow-y-auto no-scrollbar scroll-smooth flex flex-col gap-1 pr-2 pb-8">
            {allCategories.map(item => (
              <a 
                href={item.href} 
                class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm text-muted-foreground hover:bg-card/50 hover:text-foreground transition-colors border border-transparent hover:border-border/30"
              >
                <span class="text-base leading-none">{item.icon}</span>
                <span>{item.label}</span>
              </a>
            ))}
          </nav>
        </div>
      </aside>

      <!-- COLONNE DROITE (70%) : ONGLETS + GRILLE -->
      <div class="flex-1 min-w-0 flex flex-col gap-6">
        
        <!-- Menu Supérieur (Tabs de Filtrage) -->
        <nav class="flex flex-wrap items-center gap-2 border-b border-border/50 pb-4">
          {tabs.map(tab => {
            const isActive = tab.id === activeTab;
            return (
              <a
                href={tab.href}
                class:list={[
                  "inline-flex items-center justify-center px-5 py-2.5 rounded-full text-sm font-semibold transition-all duration-300",
                  isActive 
                    ? "bg-primary text-primary-foreground shadow-lg shadow-primary/20 scale-105" 
                    : "bg-card/50 border border-border/50 text-muted-foreground hover:text-foreground hover:border-primary/30"
                ]}
              >
                {tab.label}
              </a>
            );
          })}
        </nav>

        <!-- Zone d'injection du contenu spécifique à l'onglet -->
        <div class="mt-2">
          <slot />
        </div>
        
      </div>
      
    </div>
  </div>
</section>
