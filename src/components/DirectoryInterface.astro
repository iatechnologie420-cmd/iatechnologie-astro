---
import youtubeData from '@/data/youtube-videos.json';
import LogoMarquee from '@/components/LogoMarquee.astro';

const subscriberCount = youtubeData.subscriberCount || 6218;

const formatCount = (count: number) => {
  if (count >= 1_000_000) return `${(count / 1_000_000).toFixed(1)}M`;
  if (count >= 1_000) return `${Math.floor(count / 1_000)}k+`;
  return count.toString();
};

const { activeTab = 'populaires' } = Astro.props;

const tabs = [
  { id: 'populaires', label: '🔥 Les + Populaires', href: '/' },
  { id: 'gratuits', label: '💸 Gratuits', href: '/outils-ia-gratuits' },
  { id: 'nouveaux', label: '✨ Les Derniers Ajouts', href: '/nouveaux-outils-ia' },
];
---

<section id="directory" class="relative pb-12 flex flex-col justify-between">
  <!-- PREMIER BLOC : Social Proof & Marquee (Pour s'ancrer au bas de l'écran initial) -->
  <div class="container max-w-6xl mx-auto pt-0 flex flex-col gap-10">
    <!-- 1. Le Social Proof (Chiffres Clés) -->
    <div class="grid grid-cols-2 gap-6 md:flex md:flex-wrap md:items-center md:justify-center md:gap-12 animate-in fade-in duration-1000">
      <div class="flex items-center gap-4">
        <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-card border border-border/50 shadow-sm group-hover:border-primary/30 transition-colors">
          <svg class="h-5 w-5 text-[#22c55e]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
        </div>
        <div class="flex flex-col text-left">
          <span class="text-2xl font-bold font-heading leading-none text-foreground">500+</span>
          <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-muted-foreground mt-1">Outils</span>
        </div>
      </div>
      <div class="flex items-center gap-4">
        <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-card border border-border/50 shadow-sm group-hover:border-primary/30 transition-colors">
          <svg class="h-5 w-5 text-[#a855f7]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>
        </div>
        <div class="flex flex-col text-left">
          <span class="text-2xl font-bold font-heading leading-none text-foreground">18</span>
          <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-muted-foreground mt-1">Catégories</span>
        </div>
      </div>
      <div class="flex items-center gap-4">
        <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-card border border-border/50 shadow-sm group-hover:border-primary/30 transition-colors">
          <svg class="h-5 w-5 text-[#22c55e]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
        </div>
        <div class="flex flex-col text-left">
          <span class="text-2xl font-bold font-heading leading-none text-foreground">10k+</span>
          <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-muted-foreground mt-1">Visiteurs / mois</span>
        </div>
      </div>
      <div class="flex items-center gap-4">
        <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-card border border-border/50 shadow-sm group-hover:border-primary/30 transition-colors">
          <svg class="h-5 w-5 text-[#ef4444]" fill="currentColor" viewBox="0 0 24 24"><path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"/></svg>
        </div>
        <div class="flex flex-col text-left">
          <span class="text-2xl font-bold font-heading leading-none text-foreground">{formatCount(subscriberCount)}</span>
          <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-muted-foreground mt-1">YouTube</span>
        </div>
      </div>
    </div>
  </div>

  <!-- 2. Le Marquee de Logos -->
  <div class="w-full mt-10 mb-16">
    <LogoMarquee />
  </div>

  <!-- DEUXIÈME BLOC : Contrôles & Contenu -->
  <!-- Target Scroll Anchor -->
  <div id="tools-explorer" class="scroll-mt-24"></div>
  
  <div class="w-full max-w-[1920px] px-4 md:px-8 mx-auto flex flex-col gap-10">
    <!-- 3. Les 3 Boutons "Onglets" -->
    <div class="flex flex-col items-center gap-4">
      <nav class="flex flex-wrap justify-center items-center gap-4">
        {tabs.map(tab => {
          const isActive = tab.id === activeTab;
          return (
            <a
              href={tab.href}
              class:list={[
                "inline-flex items-center justify-center px-6 py-3.5 rounded-full text-base font-bold transition-all duration-300",
                isActive 
                  ? "bg-primary text-primary-foreground shadow-lg shadow-primary/20 scale-105" 
                  : "bg-card/50 border border-border/50 text-muted-foreground hover:bg-card hover:text-foreground hover:border-primary/30 hover:scale-105"
              ]}
            >
              {tab.label}
            </a>
          );
        })}
      </nav>

      <!-- Sous-filtres conditionnels pour 'Gratuits' -->
      {activeTab === 'gratuits' && (
        <div class="flex flex-wrap justify-center gap-6 mt-4 animate-in fade-in slide-in-from-top-2 duration-500">
          <label class="flex items-center gap-2 cursor-pointer group">
            <input type="checkbox" checked class="w-5 h-5 rounded border-border/50 bg-card/50 text-primary focus:ring-primary focus:ring-offset-background" />
            <span class="text-sm font-medium text-muted-foreground group-hover:text-foreground transition-colors">1er plan gratuit</span>
          </label>
          <label class="flex items-center gap-2 cursor-pointer group">
            <input type="checkbox" checked class="w-5 h-5 rounded border-border/50 bg-card/50 text-primary focus:ring-primary focus:ring-offset-background" />
            <span class="text-sm font-medium text-muted-foreground group-hover:text-foreground transition-colors">Essai gratuit</span>
          </label>
        </div>
      )}
    </div>

    <!-- 4. La Grille de Résultats -->
    <div class="w-full">
      <slot />
    </div>
  </div>
</section>
