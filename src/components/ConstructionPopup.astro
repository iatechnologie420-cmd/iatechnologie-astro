---
// src/components/ConstructionPopup.astro
---

<div id="construction-popup" class="fixed inset-0 z-[100] flex items-center justify-center p-4 sm:p-6 opacity-0 pointer-events-none transition-all duration-700 ease-out backdrop-blur-md bg-black/40">
  <div class="relative w-full max-w-lg overflow-hidden rounded-[2.5rem] border border-white/10 bg-brand-surface/90 shadow-[0_32px_64px_-16px_rgba(0,0,0,0.5)] backdrop-blur-3xl transition-all duration-700 translate-y-8 scale-95 group">
    
    <!-- Pattern deco -->
    <div class="absolute inset-0 -z-10 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 24px 24px;"></div>
    
    <!-- Glow -->
    <div class="absolute -top-24 -right-24 h-48 w-48 rounded-full bg-primary/10 blur-[80px]"></div>

    <!-- Close button -->
    <button id="close-popup" class="absolute top-6 right-6 flex h-10 w-10 items-center justify-center rounded-full border border-white/5 bg-white/5 text-white/40 transition-all hover:bg-white/10 hover:text-white group-hover:border-white/10">
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
    </button>

    <div class="p-8 sm:p-10 pt-12 text-center">
      <!-- Icon/Badge -->
      <div class="mx-auto mb-8 flex h-16 w-16 items-center justify-center rounded-2xl bg-primary/10 border border-primary/20 shadow-inner group">
        <svg class="h-8 w-8 text-primary animate-pulse" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
        </svg>
      </div>

      <!-- Title -->
      <h2 class="mb-4 font-heading text-3xl font-extrabold tracking-tight text-white sm:text-4xl">
        Migration en cours... <br />
        <span class="gradient-text">On arrive bientôt.</span>
      </h2>

      <!-- Text -->
      <p class="mb-8 text-white/60 text-base sm:text-lg leading-relaxed">
        Le site fait peau neuve ! Les articles et le répertoire de 500+ outils sont en cours de mise à jour complète.<br />
        <span class="font-semibold text-primary/80">Rendez-vous la semaine du 20 avril</span> pour l'ouverture officielle et le lancement de la newsletter.
      </p>

      <!-- Newsletter Form -->
      <div class="relative space-y-4">
        <form 
          id="popup-newsletter-form" 
          action="https://a9004679.sibforms.com/serve/MUIFACbRWtBQ58ZmHzft3_TYeb6dgjn8pxrvkPC4295ca3r6HbKwB6l48zrrXllACuSgL9wreMo-NLKumsoeeGZuh7cMZpAXoRPqk00rvRE8kb5AM5-Hq3QfTxNBvuOo-u15nR0Ir-rqLA3HAyb8X8h8pkvDgfdhzkf85zkwp3R2LJ4mKXqeZD-dpkrLcAqIMmq0uxaHh2JxaESzPQ=="
          method="POST"
          class="flex flex-col gap-3 transition-all"
        >
          <div class="relative">
            <input 
              type="email" 
              name="EMAIL"
              placeholder="votre@email.com" 
              class="w-full rounded-2xl border border-white/10 bg-white/5 px-6 py-4 text-base text-white placeholder-white/20 focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary/40 transition-all"
              required
            />
          </div>
          <input type="text" name="email_address_check" value="" class="hidden" aria-hidden="true" />
          <input type="hidden" name="locale" value="fr" />
          <button 
            type="submit" 
            class="group relative flex w-full items-center justify-center overflow-hidden rounded-2xl bg-primary px-8 py-4 text-base font-bold text-primary-foreground shadow-[0_20px_40px_-12px_rgba(var(--primary-rgb),0.3)] transition-all hover:scale-[1.02] active:scale-95"
          >
            M'avertir du lancement
          </button>
        </form>

        <!-- Success Message -->
        <div id="popup-success-message" class="hidden py-4 px-6 rounded-2xl bg-primary/10 border border-primary/20 text-primary font-bold animate-in zoom-in duration-300">
          ✨ C'est noté ! On vous écrit le 20 avril.
        </div>

        <p class="text-[10px] uppercase tracking-widest text-white/30 font-bold">
          Gratuit. Pas de spam. Exclusivités assurées.
        </p>
      </div>
    </div>
  </div>
</div>

<script>
  const popup = document.getElementById('construction-popup') as HTMLElement;
  const popupContent = popup?.querySelector('.relative') as HTMLElement;
  const closeBtn = document.getElementById('close-popup');
  const form = document.getElementById('popup-newsletter-form') as HTMLFormElement;
  const successMsg = document.getElementById('popup-success-message');

  // Check storage
  const hasSeenPopup = localStorage.getItem('iatech_migration_popup_seen');

  if (!hasSeenPopup) {
    // Show after 2s delay
    setTimeout(() => {
      popup.classList.add('opacity-100', 'pointer-events-auto');
      popupContent?.classList.remove('translate-y-8', 'scale-95');
    }, 2000);
  }

  const hidePopup = () => {
    popup.classList.remove('opacity-100', 'pointer-events-auto');
    popupContent?.classList.add('translate-y-8', 'scale-95');
    localStorage.setItem('iatech_migration_popup_seen', 'true');
  };

  closeBtn?.addEventListener('click', hidePopup);
  
  // Close on backdrop click
  popup?.addEventListener('click', (e) => {
    if (e.target === popup) hidePopup();
  });

  // Form handle
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    
    try {
      fetch(form.action, {
        method: 'POST',
        body: formData,
        mode: 'no-cors'
      });
      form.classList.add('hidden');
      successMsg?.classList.remove('hidden');
      // Close automatically after 3s on success
      setTimeout(hidePopup, 3000);
    } catch (err) {
      console.error('Error:', err);
      form.classList.add('hidden');
      successMsg?.classList.remove('hidden');
      setTimeout(hidePopup, 3000);
    }
  });
</script>
