---
const socialLinks = [
  { label: 'YouTube', href: 'https://www.youtube.com/@iatechnologiedotcom', icon: '▶️' },
  { label: 'Telegram', href: 'https://t.me/+g2lRGtpbaJA2OTJl', icon: '💬' },
  { label: 'Linktree', href: 'https://linktr.ee/iatechnologie', icon: '🔗' },
];

const navLinks = [
  { label: "Catégories d'outils", href: '/#categories' },
  { label: 'Outils populaires', href: '/#outils' },
  { label: "Cas d'usage", href: '/#cas-usage' },
  { label: 'Blog', href: '/blog' },
];

const currentYear = new Date().getFullYear();
---

<footer class="relative border-t border-border/50 noise-bg">
  <div class="absolute inset-0 bg-gradient-to-t from-card to-background"></div>

  <div class="container relative z-10 py-16">
    <div class="grid gap-12 md:grid-cols-2 lg:grid-cols-4">
      <!-- Brand -->
      <div class="lg:col-span-1 animate-on-scroll">
        <span class="font-heading text-xl font-bold tracking-wider text-foreground">
          <span class="gradient-text">IA</span> TECHNOLOGIE
        </span>
        <p class="mt-3 text-sm text-muted-foreground leading-relaxed">
          L'annuaire des meilleurs outils IA. Tests indépendants,
          comparatifs détaillés et tutoriels vidéo.
        </p>
        <div class="mt-5 flex gap-3">
          {socialLinks.map((s) => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              class="flex h-10 w-10 items-center justify-center rounded-xl glass transition-all hover:border-primary/30 hover:shadow-md hover:shadow-primary/10 hover:-translate-y-0.5"
              title={s.label}
            >
              <span class="text-lg">{s.icon}</span>
            </a>
          ))}
        </div>
      </div>

      <!-- Navigation -->
      <div class="animate-on-scroll" style="transition-delay: 0.1s;">
        <h4 class="mb-4 font-heading text-sm font-semibold text-foreground">Navigation</h4>
        <ul class="space-y-3 text-sm text-muted-foreground">
          {navLinks.map((link) => (
            <li>
              <a href={link.href} class="hover:text-primary transition-colors inline-flex items-center gap-1 group">
                <span class="h-px w-0 bg-primary transition-all duration-300 group-hover:w-3" />
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div class="animate-on-scroll" style="transition-delay: 0.2s;">
        <h4 class="mb-4 font-heading text-sm font-semibold text-foreground">Contact</h4>
        <ul class="space-y-3 text-sm text-muted-foreground">
          <li>
            <a href="mailto:hello@iatechnologie.com" class="hover:text-primary transition-colors inline-flex items-center gap-1 group">
              <span class="h-px w-0 bg-primary transition-all duration-300 group-hover:w-3" />
              hello@iatechnologie.com
            </a>
          </li>
        </ul>
      </div>

      <!-- Newsletter -->
      <div class="animate-on-scroll" style="transition-delay: 0.3s;">
        <h4 class="mb-4 font-heading text-sm font-semibold text-foreground">Newsletter</h4>
        <p class="mb-4 text-sm text-muted-foreground">
          Recevez les derniers outils IA chaque semaine.
        </p>
        <form class="flex gap-2" onsubmit="event.preventDefault();">
          <input
            type="email"
            placeholder="votre@email.com"
            class="h-10 rounded-xl bg-card/80 backdrop-blur-sm text-sm flex-1 border border-border/50 px-3 text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-1 focus:ring-primary/30"
          />
          <button type="submit" class="rounded-xl px-3 shrink-0 glow-sm h-10 bg-primary text-primary-foreground inline-flex items-center justify-center">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
          </button>
        </form>
      </div>
    </div>

    <div class="mt-12 border-t border-border/50 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-muted-foreground">
        © {currentYear} IA Technologie. Tous droits réservés.
      </p>
      <div class="flex gap-6 text-xs text-muted-foreground">
        <a href="#" class="hover:text-primary transition-colors">Mentions légales</a>
        <a href="#" class="hover:text-primary transition-colors">Politique de confidentialité</a>
      </div>
    </div>
  </div>
</footer>
