---
// YouTube data is now static — update this file with fresh data periodically
// or use an Astro API route to fetch at build time
import youtubeData from '@/data/youtube-videos.json';

const videos = youtubeData.videos || [];
const subscriberCount = youtubeData.subscriberCount || 0;

const formatCount = (count: number) => {
  if (count >= 1_000_000) return `${(count / 1_000_000).toFixed(1)}M`;
  if (count >= 1_000) return `${(count / 1_000).toFixed(1)}K`;
  return count.toLocaleString('fr-FR');
};
---

<section class="relative py-24 noise-bg overflow-hidden border-y border-border/40">
  <div class="absolute inset-0 bg-gradient-to-b from-card/90 via-background to-card/90"></div>
  <div class="container max-w-6xl mx-auto relative z-10 px-4 md:px-8">
    <div class="mb-16 text-center">
      <h2 class="mb-4 font-heading text-4xl font-bold text-foreground md:text-5xl">
        Maîtrisez l'IA : <span class="gradient-text">Nos Tutoriels en Vidéo</span>
      </h2>
      <p class="mx-auto max-w-2xl text-lg text-muted-foreground">
        Découvrez nos cas d'usage pratiques et guides d'experts pour intégrer l'intelligence artificielle dans votre quotidien.
      </p>
    </div>

    <!-- Subscriber Counter -->
    <div class="flex justify-center mb-12 ">
      <a
        href="https://www.youtube.com/@iatechnologie-com"
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center gap-4 bg-card border border-border rounded-2xl px-8 py-5 hover:border-primary/50 transition-all duration-300"
      >
        <div class="w-14 h-14 rounded-full bg-[hsl(0,100%,50%)] flex items-center justify-center">
          <svg class="w-7 h-7 text-white fill-white" viewBox="0 0 24 24"><path d="M8 5v14l11-7z" /></svg>
        </div>
        <div class="text-left">
          <p class="text-muted-foreground text-sm">Abonnés</p>
          <p class="text-3xl font-bold text-foreground">{formatCount(subscriberCount)}</p>
        </div>
        <svg class="w-4 h-4 text-muted-foreground group-hover:text-primary ml-2 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
      </a>
    </div>

    <!-- Videos Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {videos.slice(0, 6).map((video: any, i: number) => (
        <a
          href={`https://www.youtube.com/watch?v=${video.id}`}
          target="_blank"
          rel="noopener noreferrer"
          class="group bg-card rounded-xl overflow-hidden border border-border hover:border-primary/50 transition-all duration-300 "
          style={`transition-delay: ${i * 0.1}s;`}
        >
          <div class="relative aspect-video overflow-hidden">
            <img
              src={video.thumbnail}
              alt={video.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-black/30 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
              <svg class="w-12 h-12 text-white fill-white" viewBox="0 0 24 24"><path d="M8 5v14l11-7z" /></svg>
            </div>
          </div>
          <div class="p-4">
            <h3 class="text-sm font-medium text-foreground line-clamp-2 group-hover:text-primary transition-colors">{video.title}</h3>
            <p class="text-xs text-muted-foreground mt-2">
              {new Date(video.publishedAt).toLocaleDateString('fr-FR', { day: 'numeric', month: 'short', year: 'numeric' })}
            </p>
          </div>
        </a>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center mt-10 ">
      <a
        href="https://www.youtube.com/@iatechnologie-com?sub_confirmation=1"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-[hsl(0,100%,50%)] hover:bg-[hsl(0,100%,45%)] text-white font-semibold px-6 py-3 rounded-xl transition-colors"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z" /></svg>
        S'abonner à la chaîne
      </a>
    </div>
  </div>
</section>
